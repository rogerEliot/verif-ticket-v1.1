{
  "subject": "[ADMIN] Nouvelle soumission de ticket : ",
  "text": "Nouvelle soumission de ticket :\n\nDate : {{date}}\nEmail : {{email}}\nDevise : {{devise}}\n\nDétails des tickets :\n{{ticketsDetails}}\n\nMontant total : {{montantTotal}} {{devise}}",
  "html": "<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;\">\n    <h1 style=\"color: #4a6bff;\">Nouvelle soumission de ticket</h1>\n    <div style=\"background-color: #f8f9fa; padding: 15px; border-radius: 8px; margin-bottom: 20px;\">\n      <p><strong>Date :</strong> {{date}}</p>\n      <p><strong>Email :</strong> {{email}}</p>\n      <p><strong>Devise :</strong> {{devise}}</p>\n    </div>\n    \n    <h3 style=\"color: #4a6bff; border-bottom: 1px solid #e2e8f0; padding-bottom: 8px;\">Détails des tickets :</h3>\n    <table style=\"width: 100%; border-collapse: collapse; margin-top: 10px;\">\n      <thead>\n        <tr style=\"background-color: #f1f5f9; text-align: left;\">\n          <th style=\"padding: 10px; border: 1px solid #e2e8f0;\">#</th>\n          <th style=\"padding: 10px; border: 1px solid #e2e8f0;\">Type</th>\n          <th style=\"padding: 10px; border: 1px solid #e2e8f0;\">Code</th>\n          <th style=\"padding: 10px; border: 1px solid #e2e8f0; text-align: right;\">Montant</th>\n        </tr>\n      </thead>\n      <tbody>\n        {{ticketsRows}}\n      </tbody>\n      <tfoot>\n        <tr>\n          <td colspan=\"3\" style=\"text-align: right; padding: 10px; border: 1px solid #e2e8f0; font-weight: bold;\">Total :</td>\n          <td style=\"text-align: right; padding: 10px; border: 1px solid #e2e8f0; font-weight: bold; color: #4a6bff;\">\n            {{montantTotal}} {{devise}}\n          </td>\n        </tr>\n      </tfoot>\n    </table>\n    \n    <div style=\"margin-top: 30px; padding: 15px; background-color: #f0f9ff; border-radius: 8px; border-left: 4px solid #4a6bff;\">\n      <p style=\"margin: 0; color: #0369a1;\">\n        <strong>Note :</strong> Ceci est un email automatique, merci de ne pas y répondre directement.\n      </p>\n    </div>\n  </div>"
}
